# ── Base de datos ────────────────────────────────────────────────────────────
# Render PostgreSQL: copia el "External Database URL" desde el dashboard de Render
DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_db

# ── Autenticación JWT ────────────────────────────────────────────────────────
# Genera uno seguro: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia-esto-por-un-secreto-aleatorio-de-al-menos-48-caracteres

# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── Stripe ───────────────────────────────────────────────────────────────────
# Obtén estas claves desde dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# ── CORS: URL del frontend en Vercel ─────────────────────────────────────────
# Ejemplo: https://mi-app.vercel.app  (sin barra final)
# Si tienes dominio propio: https://mi-app.vercel.app,https://midominio.com
FRONTEND_URL=https://tu-app.vercel.app

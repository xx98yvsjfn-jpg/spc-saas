# ── Base de datos ────────────────────────────────────────────────────────────
# Render PostgreSQL: copia el "External Database URL" desde el dashboard de Render
DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_db

# ── Autenticación JWT ────────────────────────────────────────────────────────
# Genera uno seguro en terminal: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia-esto-por-un-secreto-aleatorio-de-al-menos-48-caracteres

# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── CORS ─────────────────────────────────────────────────────────────────────
# true  → acepta peticiones desde CUALQUIER origen (usa esto al inicio en Render)
# false → solo orígenes en la whitelist (localhost, vercel.app, FRONTEND_URL)
CORS_ALLOW_ALL=true

# URL del frontend en Vercel (sin barra final). Separa múltiples con coma.
# Ejemplo: https://mi-app.vercel.app,https://midominio.com
FRONTEND_URL=https://tu-app.vercel.app

# ── Stripe ───────────────────────────────────────────────────────────────────
# Obtén estas claves en dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
